# Copy this file to .env.local and fill in the real values from
# Supabase → Project Settings → API.

# The HTTPS URL of your Supabase project, e.g. https://abcde.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Either the publishable key (sb_publishable_...) or the legacy anon key.
# Safe to expose to the browser; RLS protects every table.
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me-with-publishable-or-anon-key
